<resources>
    <style name="CardLedgerButton" parent="Widget.MaterialComponents.Button">
        <item name="android:minHeight">52dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="CardLedgerButton.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:minHeight">52dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">14dp</item>
        <item name="strokeColor">@color/primary</item>
        <item name="android:textColor">@color/primary</item>
    </style>

    <style name="CardLedgerButton.Text" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:minHeight">48dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textColor">@color/primary</item>
    </style>

    <style name="CardLedgerButton.Danger" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:minHeight">48dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textColor">@color/danger</item>
    </style>
</resources>
